{
  "name": "earthfile",
  "rules": {
    "program": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "version"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "stmts"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "targets"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "version": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "VERSION"
        },
        {
          "type": "SYMBOL",
          "name": "_whitespace"
        },
        {
          "type": "FIELD",
          "name": "version_number",
          "content": {
            "type": "SYMBOL",
            "name": "version_number"
          }
        }
      ]
    },
    "version_number": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "[0-9]"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "."
                },
                {
                  "type": "REPEAT1",
                  "content": {
                    "type": "PATTERN",
                    "value": "[0-9]"
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "stmts": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "stmt"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "stmt"
          }
        }
      ]
    },
    "stmt": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "command_stmt"
        }
      ]
    },
    "command_stmt": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "from_stmt"
        }
      ]
    },
    "from_stmt": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "FROM"
        },
        {
          "type": "SYMBOL",
          "name": "_whitespace"
        },
        {
          "type": "SYMBOL",
          "name": "target_ref"
        }
      ]
    },
    "targets": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "target_or_user_command"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "target_or_user_command"
          }
        }
      ]
    },
    "target_or_user_command": {
      "type": "SYMBOL",
      "name": "target"
    },
    "target": {
      "type": "SEQ",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "target_header"
            },
            {
              "type": "PATTERN",
              "value": "[ \\t]*(?:\\n|\\r\\n)"
            }
          ]
        },
        {
          "type": "FIELD",
          "name": "body",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "target_block"
              },
              {
                "type": "BLANK"
              }
            ]
          }
        }
      ]
    },
    "target_header": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "ALIAS",
            "content": {
              "type": "PATTERN",
              "value": "[a-z][a-zA-Z0-9\\-.]*"
            },
            "named": true,
            "value": "name"
          }
        },
        {
          "type": "STRING",
          "value": ":"
        }
      ]
    },
    "target_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_indent"
        },
        {
          "type": "SYMBOL",
          "name": "stmt"
        },
        {
          "type": "PATTERN",
          "value": "[ \\t]*(?:\\n|\\r\\n)"
        }
      ]
    },
    "target_ref": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "local_ref"
        },
        {
          "type": "SYMBOL",
          "name": "classical_ref"
        }
      ]
    },
    "local_ref": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "+"
        },
        {
          "type": "FIELD",
          "name": "target",
          "content": {
            "type": "ALIAS",
            "content": {
              "type": "PATTERN",
              "value": "[a-z][a-z0-9\\-]*"
            },
            "named": true,
            "value": "name"
          }
        }
      ]
    },
    "classical_ref": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "ALIAS",
            "content": {
              "type": "PATTERN",
              "value": "[a-z][a-z0-9\\-]*"
            },
            "named": true,
            "value": "name"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": ":"
                },
                {
                  "type": "FIELD",
                  "name": "tag",
                  "content": {
                    "type": "ALIAS",
                    "content": {
                      "type": "PATTERN",
                      "value": "[a-z0-9\\-.]*"
                    },
                    "named": true,
                    "value": "tag"
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "_indent": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "_whitespace"
      }
    },
    "_whitespace": {
      "type": "PATTERN",
      "value": "[ \\t]"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": []
}

